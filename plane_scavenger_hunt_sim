<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Plane Flight Lab: Scavenger Hunt</title>
  <style>
    :root {
      --bg: #081225;
      --panel: #0f1d38;
      --panel2: #13274a;
      --line: rgba(255,255,255,0.1);
      --text: #edf5ff;
      --muted: #a8bddc;
      --accent: #66d6ff;
      --accent2: #ffd166;
      --good: #7ef0a7;
      --warn: #ffb454;
      --bad: #ff7b7b;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Inter, system-ui, Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top, rgba(102,214,255,0.14), transparent 28%),
        linear-gradient(180deg, #07101f 0%, #081225 100%);
      min-height: 100vh;
    }
    .app {
      max-width: 1380px;
      margin: 0 auto;
      padding: 20px;
      display: grid;
      grid-template-columns: 320px minmax(520px, 1fr) 320px;
      gap: 18px;
    }
    .panel {
      background: linear-gradient(180deg, rgba(15,29,56,0.98), rgba(10,22,43,0.96));
      border: 1px solid var(--line);
      border-radius: 24px;
      box-shadow: 0 16px 40px rgba(0,0,0,0.24);
      overflow: hidden;
    }
    .panel .inner { padding: 18px; }
    .hero {
      grid-column: 1 / -1;
      padding: 22px 24px;
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 18px;
    }
    h1 { margin: 0 0 6px; font-size: clamp(2rem, 4vw, 2.8rem); }
    .subtitle { color: var(--muted); max-width: 760px; line-height: 1.45; }
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 10px 14px;
      color: var(--accent);
      font-weight: 700;
      background: rgba(255,255,255,0.03);
      white-space: nowrap;
    }
    h2 {
      margin: 0 0 14px;
      font-size: 1rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .section + .section { margin-top: 18px; }
    .control {
      padding: 12px 0;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .control:first-of-type { border-top: 0; padding-top: 0; }
    .row {
      display: flex; justify-content: space-between; gap: 12px; align-items: center;
      margin-bottom: 8px;
    }
    .label { font-weight: 700; }
    .value { color: var(--accent2); font-weight: 800; }
    input[type=range] {
      width: 100%; accent-color: var(--accent); cursor: pointer;
    }
    select, button {
      width: 100%; border-radius: 14px; border: 1px solid var(--line);
      background: var(--panel2); color: var(--text); padding: 12px 14px; font-size: 1rem;
    }
    button {
      cursor: pointer; font-weight: 800; background: linear-gradient(135deg, #1f8fff, #5de4ff); color: #07101f;
      border: 0;
    }
    button.secondary { background: rgba(255,255,255,0.05); color: var(--text); border: 1px solid var(--line); }
    .button-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 12px; }
    .simwrap { position: relative; min-height: 760px; }
    canvas { width: 100%; aspect-ratio: 1 / 1; display: block; }
    .hud {
      position: absolute; left: 18px; top: 18px; right: 18px; display: flex; justify-content: space-between; gap: 12px;
      pointer-events: none;
    }
    .hudcard {
      background: rgba(7,16,31,0.65); backdrop-filter: blur(8px); border: 1px solid var(--line); border-radius: 18px; padding: 12px 14px;
      min-width: 190px;
    }
    .hudcard .k { color: var(--muted); font-size: 0.76rem; text-transform: uppercase; letter-spacing: 0.08em; }
    .hudcard .v { font-size: 1.2rem; font-weight: 800; margin-top: 4px; }
    .stats-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
    }
    .stat {
      border: 1px solid var(--line); border-radius: 16px; padding: 12px; background: rgba(255,255,255,0.03);
    }
    .stat .k { color: var(--muted); font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.08em; }
    .stat .v { font-size: 1.1rem; font-weight: 800; margin-top: 6px; }
    .status {
      border-radius: 16px; padding: 12px 14px; font-weight: 700; line-height: 1.45;
      background: rgba(255,255,255,0.04); border: 1px solid var(--line);
    }
    .hunt-grid { display: grid; gap: 10px; }
    .clue {
      border: 1px solid var(--line); border-radius: 16px; padding: 12px; background: rgba(255,255,255,0.03);
    }
    .clue.done { border-color: rgba(126,240,167,0.4); background: rgba(126,240,167,0.08); }
    .clue-title { font-weight: 800; margin-bottom: 4px; }
    .clue-desc { color: var(--muted); font-size: 0.92rem; line-height: 1.45; }
    .factlog {
      display: grid; gap: 10px; max-height: 270px; overflow: auto; padding-right: 4px;
    }
    .fact {
      border-left: 3px solid var(--accent2); padding: 10px 12px; border-radius: 0 14px 14px 0; background: rgba(255,255,255,0.03);
      line-height: 1.45;
    }
    .tip { color: var(--muted); font-size: 0.92rem; line-height: 1.5; }
    @media (max-width: 1150px) {
      .app { grid-template-columns: 1fr; }
      .simwrap { min-height: 520px; }
    }
  </style>
</head>
<body>
  <div class="app">
    <section class="panel hero">
      <div>
        <h1>Plane Flight Lab + Scavenger Hunt</h1>
        <div class="subtitle">Tune thrust, angle of attack, flap setting, mass, and altitude to keep a plane flying. As you explore, unlock clues about lift, drag, stalls, gliding, and why airplanes do not just “push upward.”</div>
      </div>
      <div class="pill">Find all 6 clues</div>
    </section>

    <aside class="panel">
      <div class="inner">
        <div class="section">
          <h2>Flight Setup</h2>
          <div class="control">
            <div class="row"><div class="label">Aircraft</div></div>
            <select id="planeType">
              <option value="trainer">Trainer plane</option>
              <option value="airliner">Airliner</option>
              <option value="stunt">Stunt plane</option>
              <option value="cargo">Cargo plane</option>
            </select>
          </div>
          <div class="control">
            <div class="row"><div class="label">Throttle</div><div class="value" id="throttleVal">60%</div></div>
            <input id="throttle" type="range" min="0" max="100" value="60" />
          </div>
          <div class="control">
            <div class="row"><div class="label">Pitch / Angle of attack</div><div class="value" id="aoaVal">6°</div></div>
            <input id="aoa" type="range" min="-8" max="20" value="6" />
          </div>
          <div class="control">
            <div class="row"><div class="label">Flaps</div><div class="value" id="flapsVal">0°</div></div>
            <input id="flaps" type="range" min="0" max="30" value="0" />
          </div>
          <div class="control">
            <div class="row"><div class="label">Mass</div><div class="value" id="massVal">50%</div></div>
            <input id="mass" type="range" min="30" max="100" value="50" />
          </div>
          <div class="control">
            <div class="row"><div class="label">Starting altitude</div><div class="value" id="altVal">2000 m</div></div>
            <input id="altitude" type="range" min="500" max="9000" step="100" value="2000" />
          </div>
          <div class="button-row">
            <button id="startBtn">Start / Update Flight</button>
            <button id="resetBtn" class="secondary">Reset</button>
          </div>
        </div>

        <div class="section">
          <h2>Mission Board</h2>
          <div class="status" id="missionText">Mission 1: Make the plane climb steadily without stalling.</div>
        </div>

        <div class="section">
          <h2>What to watch</h2>
          <div class="tip">A good setup balances lift, weight, thrust, and drag. Too much pitch can increase lift at first, but too much angle can stall the wing.</div>
        </div>
      </div>
    </aside>

    <main class="panel simwrap">
      <canvas id="simCanvas" width="900" height="900"></canvas>
      <div class="hud">
        <div class="hudcard">
          <div class="k">Flight state</div>
          <div class="v" id="flightState">Ready</div>
        </div>
        <div class="hudcard">
          <div class="k">Scavenger progress</div>
          <div class="v" id="progressText">0 / 6 found</div>
        </div>
      </div>
    </main>

    <aside class="panel">
      <div class="inner">
        <div class="section">
          <h2>Live Readouts</h2>
          <div class="stats-grid">
            <div class="stat"><div class="k">Lift</div><div class="v" id="liftRead">0</div></div>
            <div class="stat"><div class="k">Drag</div><div class="v" id="dragRead">0</div></div>
            <div class="stat"><div class="k">Thrust</div><div class="v" id="thrustRead">0</div></div>
            <div class="stat"><div class="k">Weight</div><div class="v" id="weightRead">0</div></div>
            <div class="stat"><div class="k">Speed</div><div class="v" id="speedRead">0 m/s</div></div>
            <div class="stat"><div class="k">Altitude</div><div class="v" id="heightRead">0 m</div></div>
          </div>
        </div>

        <div class="section">
          <h2>Scavenger Hunt</h2>
          <div class="hunt-grid" id="huntGrid"></div>
        </div>

        <div class="section">
          <h2>Unlocked Facts</h2>
          <div class="factlog" id="factLog"></div>
        </div>
      </div>
    </aside>
  </div>

  <script>
    const canvas = document.getElementById('simCanvas');
    const ctx = canvas.getContext('2d');

    const controls = {
      planeType: document.getElementById('planeType'),
      throttle: document.getElementById('throttle'),
      aoa: document.getElementById('aoa'),
      flaps: document.getElementById('flaps'),
      mass: document.getElementById('mass'),
      altitude: document.getElementById('altitude'),
      startBtn: document.getElementById('startBtn'),
      resetBtn: document.getElementById('resetBtn')
    };

    const outputs = {
      throttleVal: document.getElementById('throttleVal'),
      aoaVal: document.getElementById('aoaVal'),
      flapsVal: document.getElementById('flapsVal'),
      massVal: document.getElementById('massVal'),
      altVal: document.getElementById('altVal'),
      flightState: document.getElementById('flightState'),
      progressText: document.getElementById('progressText'),
      missionText: document.getElementById('missionText'),
      liftRead: document.getElementById('liftRead'),
      dragRead: document.getElementById('dragRead'),
      thrustRead: document.getElementById('thrustRead'),
      weightRead: document.getElementById('weightRead'),
      speedRead: document.getElementById('speedRead'),
      heightRead: document.getElementById('heightRead'),
      huntGrid: document.getElementById('huntGrid'),
      factLog: document.getElementById('factLog')
    };

    const planes = {
      trainer: { wing: 1.0, thrust: 1.0, drag: 1.0, mass: 1.0, color: '#7dd3fc' },
      airliner: { wing: 1.6, thrust: 1.2, drag: 1.15, mass: 1.6, color: '#f9fafb' },
      stunt: { wing: 0.85, thrust: 1.25, drag: 0.95, mass: 0.85, color: '#fca5a5' },
      cargo: { wing: 1.4, thrust: 1.1, drag: 1.2, mass: 1.8, color: '#fde68a' }
    };

    const missions = [
      'Mission 1: Make the plane climb steadily without stalling.',
      'Mission 2: Find a setup where the plane glides with low throttle.',
      'Mission 3: Discover how flaps help at lower speed but also increase drag.'
    ];

    const clues = [
      { id: 'climb', title: 'Clue 1: Climb', desc: 'Make the plane gain altitude for at least 4 seconds.', fact: 'Airplanes climb when lift and thrust work together strongly enough to beat weight and drag.', check: s => s.altitude > s.startAltitude + 250 && s.time > 4 },
      { id: 'stall', title: 'Clue 2: Stall', desc: 'Trigger a stall by pitching too high.', fact: 'A wing can stall even while still moving forward if the angle of attack gets too large.', check: s => s.state === 'Stall' },
      { id: 'glide', title: 'Clue 3: Glide', desc: 'Keep flying with throttle below 20%.', fact: 'Planes do not need full engine power to stay in the air. A glider proves lift can exist without thrust.', check: s => s.throttle < 20 && s.speed > 45 && s.altitude > 500 && s.time > 3 },
      { id: 'flaps', title: 'Clue 4: Flaps', desc: 'Use flaps at 15° or more while staying airborne.', fact: 'Flaps increase lift at lower speed, but they also create much more drag.', check: s => s.flaps >= 15 && s.altitude > 300 && s.speed > 40 && s.time > 2 },
      { id: 'heavy', title: 'Clue 5: Weight', desc: 'Fly with mass at 85% or more.', fact: 'A heavier aircraft needs more lift, which often means more speed, more wing performance, or both.', check: s => s.mass >= 85 && s.altitude > 300 && s.speed > 55 && s.time > 3 },
      { id: 'fast', title: 'Clue 6: Drag tradeoff', desc: 'Fly fast with low pitch and low flaps.', fact: 'At high speed, extra flap or pitch can add unnecessary drag and waste energy.', check: s => s.speed > 90 && s.aoa <= 5 && s.flaps <= 5 && s.time > 2 }
    ];

    let unlocked = new Set();
    let facts = [];
    let sim = null;
    let animId = null;

    function initHunt() {
      outputs.huntGrid.innerHTML = '';
      clues.forEach(clue => {
        const div = document.createElement('div');
        div.className = 'clue';
        div.id = `clue-${clue.id}`;
        div.innerHTML = `<div class="clue-title">${clue.title}</div><div class="clue-desc">${clue.desc}</div>`;
        outputs.huntGrid.appendChild(div);
      });
      renderFacts();
      updateProgress();
    }

    function renderFacts() {
      outputs.factLog.innerHTML = facts.length
        ? facts.map(f => `<div class="fact">${f}</div>`).join('')
        : `<div class="tip">Unlock clues to fill this log.</div>`;
    }

    function updateProgress() {
      outputs.progressText.textContent = `${unlocked.size} / ${clues.length} found`;
      clues.forEach(c => {
        document.getElementById(`clue-${c.id}`).classList.toggle('done', unlocked.has(c.id));
      });
    }

    function readControls() {
      return {
        planeType: controls.planeType.value,
        throttle: +controls.throttle.value,
        aoa: +controls.aoa.value,
        flaps: +controls.flaps.value,
        mass: +controls.mass.value,
        altitude: +controls.altitude.value
      };
    }

    function updateLabels() {
      outputs.throttleVal.textContent = `${controls.throttle.value}%`;
      outputs.aoaVal.textContent = `${controls.aoa.value}°`;
      outputs.flapsVal.textContent = `${controls.flaps.value}°`;
      outputs.massVal.textContent = `${controls.mass.value}%`;
      outputs.altVal.textContent = `${controls.altitude.value} m`;
    }

    function resetSim() {
      cancelAnimationFrame(animId);
      unlocked = new Set();
      facts = [];
      controls.planeType.value = 'trainer';
      controls.throttle.value = 60;
      controls.aoa.value = 6;
      controls.flaps.value = 0;
      controls.mass.value = 50;
      controls.altitude.value = 2000;
      updateLabels();
      initHunt();
      outputs.flightState.textContent = 'Ready';
      outputs.missionText.textContent = missions[0];
      sim = makeSimState();
      draw();
      updateOutputs();
    }

    function makeSimState() {
      const c = readControls();
      const p = planes[c.planeType];
      return {
        ...c,
        startAltitude: c.altitude,
        x: 120,
        y: 0,
        speed: 62,
        verticalSpeed: 0,
        pitchVisual: c.aoa,
        time: 0,
        state: 'Cruising',
        plane: p
      };
    }

    function calcForces(s) {
      const density = Math.max(0.45, 1.18 - s.altitude / 12000 * 0.5);
      const liftCoeff = (0.28 + s.aoa * 0.055 + s.flaps * 0.022) * s.plane.wing;
      const dragCoeff = (0.16 + Math.max(0, s.aoa) * 0.018 + s.flaps * 0.03) * s.plane.drag;
      const thrust = (s.throttle / 100) * 120 * s.plane.thrust;
      const weight = (50 + s.mass * 1.6) * s.plane.mass;
      const lift = density * Math.max(0, s.speed) * liftCoeff;
      const drag = density * Math.max(0, s.speed) * dragCoeff;
      const stallAoA = 14 - s.flaps * 0.08;
      const stalled = s.aoa > stallAoA && s.speed < 82;
      return { lift, drag, thrust, weight, stalled };
    }

    function step() {
      const c = readControls();
      Object.assign(sim, c, { plane: planes[c.planeType] });
      const f = calcForces(sim);
      const accel = (f.thrust - f.drag) * 0.018;
      sim.speed = Math.max(20, sim.speed + accel);

      let liftNet = (f.lift - f.weight) * 0.016;
      if (f.stalled) liftNet -= 2.8;
      sim.verticalSpeed += liftNet;
      sim.verticalSpeed *= 0.93;
      sim.altitude = Math.max(0, sim.altitude + sim.verticalSpeed * 1.8);
      sim.x += sim.speed * 0.55;
      sim.time += 0.05;
      sim.pitchVisual += (sim.aoa - sim.pitchVisual) * 0.08;

      if (sim.altitude <= 0 && sim.time > 0.5) sim.state = 'Landed';
      else if (f.stalled) sim.state = 'Stall';
      else if (sim.verticalSpeed > 2) sim.state = 'Climbing';
      else if (sim.verticalSpeed < -2 && sim.throttle < 25) sim.state = 'Gliding';
      else if (sim.speed > 95) sim.state = 'Fast cruise';
      else sim.state = 'Cruising';

      sim.forces = f;
      checkClues();
      updateOutputs();
      draw();
      animId = requestAnimationFrame(step);
    }

    function checkClues() {
      clues.forEach((clue, idx) => {
        if (!unlocked.has(clue.id) && clue.check(sim)) {
          unlocked.add(clue.id);
          facts.unshift(clue.fact);
          outputs.missionText.textContent = idx < missions.length ? missions[Math.min(idx + 1, missions.length - 1)] : 'Keep experimenting and collect the rest of the clues.';
        }
      });
      updateProgress();
      renderFacts();
    }

    function updateOutputs() {
      const f = sim.forces || calcForces(sim);
      outputs.flightState.textContent = sim.state;
      outputs.liftRead.textContent = `${f.lift.toFixed(0)} units`;
      outputs.dragRead.textContent = `${f.drag.toFixed(0)} units`;
      outputs.thrustRead.textContent = `${f.thrust.toFixed(0)} units`;
      outputs.weightRead.textContent = `${f.weight.toFixed(0)} units`;
      outputs.speedRead.textContent = `${sim.speed.toFixed(0)} m/s`;
      outputs.heightRead.textContent = `${sim.altitude.toFixed(0)} m`;
    }

    function drawBackground(w, h) {
      const grad = ctx.createLinearGradient(0, 0, 0, h);
      grad.addColorStop(0, '#021029');
      grad.addColorStop(1, '#083361');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, w, h);
      for (let i = 0; i < 80; i++) {
        const x = (i * 97) % w;
        const y = (i * 57 + 20) % (h * 0.7);
        const r = (i % 3) + 1;
        ctx.fillStyle = `rgba(255,255,255,${0.08 + (i % 5) * 0.04})`;
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fill();
      }
      const groundY = h * 0.8;
      ctx.fillStyle = '#1f5132';
      ctx.fillRect(0, groundY, w, h - groundY);
      ctx.fillStyle = '#295f3a';
      for (let i = 0; i < 8; i++) {
        ctx.beginPath();
        ctx.arc(i * w / 7, groundY + 45, 100, Math.PI, 0);
        ctx.fill();
      }
      ctx.fillStyle = '#dbeafe';
      ctx.fillRect(50, groundY - 8, w - 100, 16);
    }

    function drawPlane(x, y, scale, color, angleDeg) {
      ctx.save();
      ctx.translate(x, y);
      ctx.rotate(angleDeg * Math.PI / 180);
      ctx.scale(scale, scale);
      ctx.fillStyle = color;
      ctx.strokeStyle = 'rgba(255,255,255,0.7)';
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.moveTo(-32, 0);
      ctx.lineTo(18, -8);
      ctx.lineTo(34, 0);
      ctx.lineTo(18, 8);
      ctx.closePath();
      ctx.fill();
      ctx.stroke();
      ctx.fillRect(-6, -22, 12, 44);
      ctx.fillRect(-24, -5, 18, 10);
      ctx.fillStyle = '#93c5fd';
      ctx.fillRect(2, -5, 9, 10);
      ctx.restore();
    }

    function drawForceArrow(x, y, dx, dy, label, color) {
      ctx.save();
      ctx.strokeStyle = color;
      ctx.fillStyle = color;
      ctx.lineWidth = 4;
      ctx.beginPath();
      ctx.moveTo(x, y);
      ctx.lineTo(x + dx, y + dy);
      ctx.stroke();
      const ang = Math.atan2(dy, dx);
      ctx.beginPath();
      ctx.moveTo(x + dx, y + dy);
      ctx.lineTo(x + dx - 12 * Math.cos(ang - 0.4), y + dy - 12 * Math.sin(ang - 0.4));
      ctx.lineTo(x + dx - 12 * Math.cos(ang + 0.4), y + dy - 12 * Math.sin(ang + 0.4));
      ctx.closePath();
      ctx.fill();
      ctx.font = '700 16px Inter';
      ctx.fillText(label, x + dx + 8, y + dy + 4);
      ctx.restore();
    }

    function draw() {
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * devicePixelRatio;
      canvas.height = rect.height * devicePixelRatio;
      ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
      const w = rect.width;
      const h = rect.height;
      drawBackground(w, h);
      const groundY = h * 0.8;
      const px = Math.min(w * 0.68, 120 + sim.x * 0.12);
      const py = groundY - 30 - sim.altitude * 0.05;
      drawPlane(px, py, 1.7, sim.plane.color, -sim.pitchVisual);
      const f = sim.forces || calcForces(sim);
      drawForceArrow(px - 10, py, 0, -Math.min(85, f.lift * 0.12), 'Lift', '#7ef0a7');
      drawForceArrow(px + 10, py, 0, Math.min(85, f.weight * 0.06), 'Weight', '#ff7b7b');
      drawForceArrow(px - 4, py + 16, Math.min(90, f.thrust * 0.18), 0, 'Thrust', '#66d6ff');
      drawForceArrow(px - 4, py - 16, -Math.min(90, f.drag * 0.32), 0, 'Drag', '#ffd166');
    }

    controls.startBtn.addEventListener('click', () => {
      cancelAnimationFrame(animId);
      sim = makeSimState();
      animId = requestAnimationFrame(step);
    });

    controls.resetBtn.addEventListener('click', resetSim);
    Object.values(controls).forEach(el => {
      if (el.tagName === 'INPUT' || el.tagName === 'SELECT') el.addEventListener('input', updateLabels);
    });

    resetSim();
  </script>
</body>
</html>
